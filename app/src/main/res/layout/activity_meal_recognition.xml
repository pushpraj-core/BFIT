<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/mealToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:title="@string/meal_recognition_title" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_md">

            <TextView
                android:id="@+id/mealIntroText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/meal_pick_hint"
                android:textAppearance="?attr/textAppearanceBodyMedium" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.BFIT.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_sm">

                    <ImageView
                        android:id="@+id/mealImagePreview"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:adjustViewBounds="true"
                        android:background="@color/bfit_surface_soft"
                        android:contentDescription="@string/selected_meal_image_cd"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_baseline_restaurant_24" />

                    <TextView
                        android:id="@+id/emptyMealState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/meal_empty_state"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/bfit_warning" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/selectImageButton"
                            style="@style/Widget.BFIT.ActionButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/select_meal_photo" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/retakeImageButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_xs"
                            android:layout_weight="1"
                            android:text="@string/retake_photo" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/analyzeMealButton"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:minHeight="@dimen/touch_target_min"
                        android:text="@string/analyze_meal" />

                    <ProgressBar
                        android:id="@+id/analyzeProgress"
                        style="?android:attr/progressBarStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/space_xs"
                        android:visibility="gone" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/confidenceChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/confidence_placeholder"
                        app:chipBackgroundColor="@color/bfit_secondary_container" />

                    <TextView
                        android:id="@+id/mealRecognitionResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/no_analysis_yet"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/estimated_macros"
                        android:textAppearance="?attr/textAppearanceTitleMedium" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:fillViewport="true"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="3">

                        <TextView
                            android:id="@+id/proteinMacroText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/macro_protein_placeholder"
                            android:textColor="@color/bfit_success" />

                        <TextView
                            android:id="@+id/carbsMacroText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/macro_carbs_placeholder"
                            android:textColor="@color/bfit_warning" />

                        <TextView
                            android:id="@+id/fatsMacroText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/macro_fats_placeholder"
                            android:textColor="@color/bfit_danger" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/addToLogButton"
                        style="@style/Widget.BFIT.ActionButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/add_to_daily_log"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
